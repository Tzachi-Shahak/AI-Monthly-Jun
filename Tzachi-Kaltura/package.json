{
  "name": "slidev-theme-tzachi-kaltura",
  "version": "0.0.0",
  "type": "module",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "build": "slidev build example.md",
    "dev": "slidev example.md --open",
    "export": "slidev export example.md",
    "screenshot": "slidev export example.md --format png"
  },
  "dependencies": {
    "@slidev/types": "^52.15.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.0"
  },
  "//": "Learn more: https://sli.dev/guide/write-theme.html",
  "slidev": {
    "colorSchema": "light",
    "defaults": {
      "layout": "default",
      "fonts": {
        "sans": "DM Sans",
        "mono": "Fira Code",
        "weights": "400,500,600,700"
      }
    }
  }
}